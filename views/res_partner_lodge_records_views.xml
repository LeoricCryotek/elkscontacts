<odoo>
  <data>
    <record id="view_partner_form_lodge_records" model="ir.ui.view">
      <field name="name">res.partner.form.lodge.records</field>
      <field name="model">res.partner</field>
      <field name="inherit_id" ref="elkscontacts.view_partner_form_elks"/>
      <field name="priority" eval="20"/>
      <field name="arch" type="xml">
        <xpath expr="//page[@name='clms_tab']" position="after">
          <page string="Lodge Records" name="lodge_records" invisible="not x_is_member and not x_is_volunteer">
            <group>
              <group string="Access">
                <field name="x_local_door_code"/>
                <field name="x_local_has_key"/>
                <field name="x_local_key_numbers"
                       placeholder="e.g. 101, 102"
                       invisible="not x_local_has_key"/>
              </group>
              <group string="Membership Card" invisible="not x_is_member">
                <field name="x_local_card_delivery"/>
                <field name="x_local_card_delivery_date"
                       invisible="x_local_card_delivery == 'not_delivered'"/>
              </group>
              <group string="Volunteer Roles" invisible="not x_is_volunteer">
                <field name="x_local_volunteer_active"/>
                <field name="x_local_bartender" invisible="not x_local_volunteer_active"/>
                <field name="x_local_kitchen" invisible="not x_local_volunteer_active"/>
                <field name="x_local_sanitation" invisible="not x_local_volunteer_active"/>
              </group>
            </group>
            <!-- Non-Elks Member toggle removed — redundant with x_is_member toggle at top -->
          </page>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
