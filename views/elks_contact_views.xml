<odoo>
    <!-- Contact type toggles at top of contact form -->
    <record id="view_partner_form_elks_member_flag" model="ir.ui.view">
        <field name="name">res.partner.form.elks.member.flag</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="10"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_type']" position="after">
                <div class="d-flex gap-4 mt-2 mb-2 align-items-center">
                    <div class="d-flex align-items-center gap-1">
                        <label for="x_is_member" string="Elk"/>
                        <field name="x_is_member" widget="boolean_toggle"/>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <label for="x_is_volunteer" string="Volunteer"/>
                        <field name="x_is_volunteer" widget="boolean_toggle"/>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <label for="x_is_customer" string="Customer"/>
                        <field name="x_is_customer" widget="boolean_toggle"/>
                    </div>
                    <div class="d-flex align-items-center gap-1"
                         invisible="not x_is_member">
                        <label for="x_is_initiate" string="Initiate"/>
                        <field name="x_is_initiate" widget="boolean_toggle"/>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <label for="x_is_guest" string="Guest"/>
                        <field name="x_is_guest" widget="boolean_toggle"/>
                    </div>
                </div>
                <field name="x_volunteer_employee_id" invisible="1"/>
                <div class="d-flex gap-2 align-items-center"
                     invisible="not x_is_volunteer">
                    <button name="action_open_volunteer_link_wizard"
                            string="Link / Create Employee"
                            type="object"
                            class="btn-primary btn-sm"
                            icon="fa-link"
                            invisible="x_volunteer_employee_id"
                            help="Open the wizard to pick an existing employee to link, or create a new one"/>
                    <span class="text-muted small"
                          invisible="x_volunteer_employee_id">
                        No employee linked yet.
                    </span>
                    <span class="text-success small"
                          invisible="not x_volunteer_employee_id">
                        <i class="fa fa-check-circle" title="Linked"/> Linked to employee.
                    </span>
                    <button name="action_open_employee_merge_wizard"
                            string="Merge Duplicates"
                            type="object"
                            class="btn-link btn-sm"
                            icon="fa-compress"
                            help="Merge duplicate HR employee records for this contact"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Return to Sender banner + button on contact form -->
    <record id="view_partner_form_elks_rts" model="ir.ui.view">
        <field name="name">res.partner.form.elks.rts</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="11"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="inside">
                <field name="x_return_to_sender" invisible="1"/>
                <!-- Alert banner when RTS is flagged -->
                <div class="alert alert-warning mb-3"
                     role="alert"
                     invisible="not x_return_to_sender">
                    <i class="fa fa-exclamation-triangle" title="Warning"/>
                    <strong> Return to Sender</strong> —
                    Mail returned as undeliverable
                    <span invisible="not x_return_to_sender_date">
                        on <field name="x_return_to_sender_date" readonly="1" class="d-inline"/>
                    </span>.
                    Please verify and update the mailing address.
                    <button name="action_clear_return_to_sender"
                            type="object"
                            string="Clear RTS Flag"
                            class="btn-sm btn-warning ms-3"
                            icon="fa-check"/>
                </div>
            </xpath>
            <!-- Mark RTS button in the form header area -->
            <xpath expr="//form/sheet/div[hasclass('oe_button_box')]" position="inside">
                <button name="action_mark_return_to_sender"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-envelope-o"
                        invisible="x_return_to_sender">
                    <span>Mark RTS</span>
                </button>
                <button name="action_clear_return_to_sender"
                        type="object"
                        class="oe_stat_button text-warning"
                        icon="fa-exclamation-triangle"
                        invisible="not x_return_to_sender">
                    <span>RTS Flagged</span>
                </button>
            </xpath>
        </field>
    </record>

    <!-- CLMS tab on res.partner (visible only for members) -->
    <record id="view_partner_form_elks" model="ir.ui.view">
        <field name="name">res.partner.form.elks</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- CLMS tab first: insert before the built-in Contacts page -->
            <xpath expr="//form/sheet/notebook/page[@name='contact_addresses']" position="before">
                <page string="CLMS" invisible="not x_is_member"
                      name="clms_tab" autofocus="autofocus">
                    <group>
                        <group string="Membership">
                            <field name="x_detail_id" string="Record ID"/>
                            <field name="x_detail_member_num" string="Member Number"/>
                            <field name="x_detail_lodge_id" string="Lodge ID"/>
                            <field name="x_detail_lodge_num" string="Lodge Number"/>
                            <field name="x_lodge_report_lodge_name" string="Lodge Name"/>
                            <field name="x_detail_elk_title" string="Elks Title"/>
                            <field name="x_detail_dues_paid_to_date" string="Dues Paid To Date"/>
                            <field name="x_detail_delinquent_months" string="Delinquent Months"/>
                            <field name="x_enotices_ok" string="E-Notices OK"/>
                        </group>
                        <group string="Name">
                            <field name="x_detail_name_prefix" string="Name Prefix"/>
                            <field name="x_detail_name_salutation" string="Salutation"/>
                            <field name="x_detail_first_name" string="First Name"/>
                            <field name="x_detail_middle_name" string="Middle Name"/>
                            <field name="x_detail_last_name" string="Last Name"/>
                            <field name="x_detail_name_suffix" string="Name Suffix"/>
                            <field name="x_maiden_name" string="Maiden Name"/>
                        </group>
                    </group>

                    <group>
                        <group string="Active Address (Raw)">
                            <field name="x_detail_active_address_line1" string="Address Line 1"/>
                            <field name="x_detail_active_address_line2" string="Address Line 2"/>
                            <field name="x_detail_active_city" string="City"/>
                            <field name="x_detail_active_state" string="State"/>
                            <field name="x_detail_active_zip" string="ZIP"/>
                            <field name="x_detail_active_country" string="Country"/>
                        </group>
                        <group string="USPS / CASS">
                            <field name="x_detail_active_carrier_code" string="Carrier Code"/>
                            <field name="x_detail_active_dpc" string="DPC"/>
                            <field name="x_detail_active_postal_lot" string="Postal LOT"/>
                            <field name="x_detail_active_usps_type" string="USPS Type"/>
                            <field name="x_detail_active_cass_result_code" string="CASS Result Code"/>
                            <field name="x_detail_active_send_no_mail" string="Do Not Mail"/>
                            <field name="x_detail_active_send_no_magazine" string="Do Not Send Magazine"/>
                            <field name="x_detail_active_is_undeliverable" string="Undeliverable"/>
                        </group>
                    </group>

                    <group>
                        <group string="Household">
                            <field name="x_detail_spouse_first_name" string="Spouse First Name"/>
                            <field name="x_detail_spouse_last_name" string="Spouse Last Name"/>
                            <field name="x_detail_head_of_household_num" string="Head of Household #"/>
                            <field name="x_detail_is_head_of_household" string="Is Head of Household"/>
                        </group>
                        <group string="Phones &amp; Email (Raw)">
                            <field name="x_detail_email_address" string="Email Address"/>
                            <field name="x_detail_home_area_code" string="Home Area Code"/>
                            <field name="x_detail_home_phone" string="Home Phone"/>
                            <field name="x_detail_home_phone_ext" string="Home Phone Ext"/>
                            <field name="x_detail_cell_area_code" string="Cell Area Code"/>
                            <field name="x_detail_cell_phone" string="Cell Phone"/>
                            <field name="x_detail_fax_area_code" string="Fax Area Code"/>
                            <field name="x_detail_fax_phone" string="Fax Phone"/>
                            <field name="x_detail_work_area_code" string="Work Area Code"/>
                            <field name="x_detail_work_phone" string="Work Phone"/>
                            <field name="x_detail_work_phone_ext" string="Work Phone Ext"/>
                        </group>
                    </group>

                    <group>
                        <group string="Dates / Years">
                            <field name="x_last_life_date" string="Last Life Date"/>
                            <field name="x_last_hon_life_date" string="Last Honor Life Date"/>
                            <field name="x_detail_per_start_year" string="PER Start Year"/>
                            <field name="x_years_as_per" string="Years as PER"/>
                            <field name="x_detail_pey_start_year" string="PEY Start Year"/>
                            <field name="x_years_as_pey" string="Years as PEY"/>
                            <field name="x_detail_poy_start_year" string="POY Start Year"/>
                            <field name="x_years_as_poy" string="Years as POY"/>
                        </group>
                        <group string="Other">
                            <field name="x_branch_of_service" string="Branch of Service"/>
                            <field name="x_discharge_type" string="Discharge Type"/>
                            <field name="x_discharge_date" string="Discharge Date"/>
                            <field name="x_sortfield" string="Sort Field"/>
                            <field name="x_original_index" string="Original Index"/>
                            <field name="x_detail_user_value_001" string="User Value 001"/>
                            <field name="x_detail_user_value_002" string="User Value 002"/>
                            <field name="x_detail_user_value_003" string="User Value 003"/>
                            <field name="x_detail_user_value_004" string="User Value 004"/>
                            <field name="x_detail_user_value_005" string="User Value 005"/>
                            <field name="x_detail_user_value_006" string="User Value 006"/>
                            <field name="x_detail_user_value_007" string="User Value 007"/>
                            <field name="x_detail_user_value_008" string="User Value 008"/>
                            <field name="x_detail_user_value_009" string="User Value 009"/>
                        </group>
                    </group>
                </page>

                <page string="Elks History" name="elks_history"
                      invisible="not x_is_member and not x_is_initiate">

                    <!-- Titles &amp; Honors -->
                    <group string="Current Title &amp; Honors">
                        <group>
                            <field name="x_elks_officer_position" string="Current Officer Position"/>
                            <field name="x_elks_officer_type" string="Officer Type"/>
                            <field name="x_detail_elk_title" string="Elks Title"/>
                        </group>
                        <group>
                            <field name="x_detail_per_start_year" string="PER Since"/>
                            <field name="x_years_as_per" string="Years as PER"/>
                            <field name="x_detail_pey_start_year" string="PEY Since"/>
                            <field name="x_years_as_pey" string="Years as PEY"/>
                            <field name="x_detail_poy_start_year" string="POY Since"/>
                            <field name="x_years_as_poy" string="Years as POY"/>
                            <field name="x_last_life_date" string="Life Member Date"/>
                            <field name="x_last_hon_life_date" string="Honorary Life Date"/>
                        </group>
                    </group>

                    <separator string="Officer Term History"/>
                    <field name="x_officer_term_ids" readonly="1">
                        <list>
                            <field name="lodge_year"/>
                            <field name="position"/>
                            <field name="officer_type"/>
                            <field name="partial_year"/>
                            <field name="notes"/>
                        </list>
                    </field>

                    <separator string="Committee Assignments"/>
                    <field name="x_committee_assignment_ids" readonly="1">
                        <list>
                            <field name="lodge_year"/>
                            <field name="committee_id"/>
                            <field name="role"/>
                            <field name="date_appointed"/>
                            <field name="date_ended"/>
                            <field name="is_current"/>
                            <field name="notes"/>
                        </list>
                    </field>

                    <separator string="Membership Application History"/>
                    <field name="x_membership_application_ids" readonly="1">
                        <list>
                            <field name="name" string="Reference"/>
                            <field name="stage"/>
                            <field name="date_proposed"/>
                            <field name="proposer_id" string="Proposed By"/>
                            <field name="ballot_result"/>
                            <field name="date_elected"/>
                            <field name="date_initiated"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

