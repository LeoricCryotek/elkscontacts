<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_elks_charitable_tree" model="ir.ui.view">
        <field name="name">elks.charitable.activity.tree</field>
        <field name="model">elks.charitable.activity</field>
        <field name="arch" type="xml">
            <list string="Charitable Activities">
                <field name="date"/>
                <field name="name"/>
                <field name="category"/>
                <field name="lodge_year"/>
                <field name="cash_donated" sum="Cash"/>
                <field name="goods_value" sum="Goods"/>
                <field name="total_value" sum="Total"/>
                <field name="volunteer_hours" sum="Hours"/>
                <field name="volunteer_count" sum="Volunteers"/>
                <field name="people_served" sum="Served"/>
                <field name="committee_id" optional="show"/>
                <field name="lead_partner_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_elks_charitable_form" model="ir.ui.view">
        <field name="name">elks.charitable.activity.form</field>
        <field name="model">elks.charitable.activity</field>
        <field name="arch" type="xml">
            <form string="Charitable Activity">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="date"/>
                            <field name="lodge_year" readonly="1"/>
                            <field name="committee_id"/>
                            <field name="lead_partner_id"/>
                            <field name="recipient_org"/>
                        </group>
                        <group string="Contributions">
                            <field name="cash_donated"/>
                            <field name="goods_value"/>
                            <field name="total_value" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="volunteer_hours"/>
                            <field name="volunteer_count"/>
                            <field name="people_served"/>
                        </group>
                    </group>
                    <group string="Accounting" invisible="not journal_entry_ref">
                        <field name="journal_entry_ref"/>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_elks_charitable_pivot" model="ir.ui.view">
        <field name="name">elks.charitable.activity.pivot</field>
        <field name="model">elks.charitable.activity</field>
        <field name="arch" type="xml">
            <pivot string="Charitable Giving Report">
                <field name="category" type="row"/>
                <field name="lodge_year" type="col"/>
                <field name="cash_donated" type="measure"/>
                <field name="goods_value" type="measure"/>
                <field name="total_value" type="measure"/>
                <field name="volunteer_hours" type="measure"/>
                <field name="people_served" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_elks_charitable_search" model="ir.ui.view">
        <field name="name">elks.charitable.activity.search</field>
        <field name="model">elks.charitable.activity</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category"/>
                <field name="lodge_year"/>
                <field name="committee_id"/>
                <filter name="has_cash" string="Cash Donations"
                        domain="[('cash_donated', '&gt;', 0)]"/>
                <filter name="has_hours" string="With Volunteer Hours"
                        domain="[('volunteer_hours', '&gt;', 0)]"/>
                <group>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category'}"/>
                    <filter name="group_year" string="Lodge Year"
                            context="{'group_by': 'lodge_year'}"/>
                    <filter name="group_committee" string="Committee"
                            context="{'group_by': 'committee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_elks_charitable" model="ir.actions.act_window">
        <field name="name">Charitable Activities</field>
        <field name="res_model">elks.charitable.activity</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="context">{
            'search_default_group_category': 1,
            'search_default_group_year': 1,
        }</field>
    </record>
</odoo>
