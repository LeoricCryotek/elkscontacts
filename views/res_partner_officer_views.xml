<odoo>
  <record id="view_partner_form_elks_row_after_address" model="ir.ui.view">
    <field name="name">res.partner.form.elks.row.after.address</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="elkscontacts.view_partner_form_lodge_records"/>
    <field name="priority" eval="25"/>
    <field name="arch" type="xml">

      <!-- Insert a new label+field row AFTER the entire Address box -->
      <xpath expr="//div[hasclass('o_address_format')]" position="after">
        <!-- make trigger available -->
        <field name="x_is_not_member" invisible="1"/>

        <!-- Left-side label (same style as Address/Company labels) -->
        <span class="o_form_label o_td_label">Elks</span>

        <!-- Right-side content box -->
        <div class="o_td_field" invisible="x_is_not_member">
          <div class="d-flex flex-wrap gap-2">
            <field name="x_elks_officer_position" string="Current Officer Position"/>
            <field name="x_elks_officer_type" readonly="1" string="Officer Type"/>
            <field name="x_is_elks_officer" readonly="1" string="Is Officer"/>
          </div>
        </div>
      </xpath>

      <!-- Officer History tab removed — officer terms are managed
           in the Elks History tab and via the standalone Officer Terms menu -->

    </field>
  </record>

  <!-- ============================================================
       Standalone Officer Term views (for menu access)
       ============================================================ -->

  <record id="view_elks_officer_term_list" model="ir.ui.view">
    <field name="name">elks.officer.term.list</field>
    <field name="model">elks.officer.term</field>
    <field name="arch" type="xml">
      <list decoration-muted="not active">
        <field name="active" column_invisible="1"/>
        <field name="lodge_year"/>
        <field name="position"/>
        <field name="partner_id"/>
        <field name="officer_type"/>
        <field name="partial_year"/>
        <field name="date_start" optional="show"/>
        <field name="date_end" optional="show"/>
        <field name="gender" optional="show"/>
        <field name="show_on_website" optional="show"/>
        <field name="message" optional="hide"/>
      </list>
    </field>
  </record>

  <record id="view_elks_officer_term_form" model="ir.ui.view">
    <field name="name">elks.officer.term.form</field>
    <field name="model">elks.officer.term</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <div class="oe_button_box" name="button_box"/>
          <field name="image_1920" widget="image" class="oe_avatar"
                 options="{'preview_image': 'image_1920'}"/>
          <div class="oe_title">
            <h1><field name="display_name"/></h1>
          </div>
          <group>
            <group string="Position Details">
              <field name="partner_id"/>
              <field name="position"/>
              <field name="officer_type"/>
              <field name="lodge_year"/>
              <field name="partial_year"/>
              <field name="date_start"/>
              <field name="date_end"/>
              <field name="gender"/>
            </group>
            <group string="Website Display">
              <field name="officer_email" widget="email"/>
              <field name="officer_phone" widget="phone"/>
              <field name="show_on_website"/>
            </group>
          </group>
          <separator string="Public Message"/>
          <field name="message" nolabel="1"
                 placeholder="Write a public bio or message for the website..."/>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_elks_officer_term_search" model="ir.ui.view">
    <field name="name">elks.officer.term.search</field>
    <field name="model">elks.officer.term</field>
    <field name="arch" type="xml">
      <search>
        <field name="partner_id"/>
        <field name="position"/>
        <field name="lodge_year"/>
        <separator/>
        <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
        <filter name="filter_archived" string="Archived"
                domain="[('active', '=', False)]"/>
        <filter name="filter_partial" string="Partial Year"
                domain="[('partial_year', '=', True)]"/>
        <separator/>
        <filter name="group_year" string="Lodge Year" context="{'group_by': 'lodge_year'}"/>
        <filter name="group_position" string="Position" context="{'group_by': 'position'}"/>
        <filter name="group_type" string="Officer Type" context="{'group_by': 'officer_type'}"/>
      </search>
    </field>
  </record>

  <!-- Action to open Officer Terms -->
  <record id="action_elks_officer_terms" model="ir.actions.act_window">
    <field name="name">Officer Terms</field>
    <field name="res_model">elks.officer.term</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        No officer terms recorded yet.
      </p>
      <p>
        Track which members hold officer positions each lodge year.
      </p>
    </field>
  </record>

</odoo>
