             ============================================================= -->
        <record id="committee_1000" model="elks.committee">
            <field name="name">Auditing &amp; Accounting Committee</field>
            <field name="sort_code">1000</field>
            <field name="committee_type">statutory</field>

            <field name="description">Reviews and audits the financial records of the lodge. Required by Grand Lodge statutes.</field>
        </record>

