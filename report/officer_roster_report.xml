<odoo>

  <!-- Report action (appears in Print menu and can be called from menu) -->
  <record id="action_report_officer_roster" model="ir.actions.report">
    <field name="name">Officer Roster</field>
    <field name="model">elks.officer.term</field>
    <field name="report_type">qweb-html</field>
    <field name="report_name">elkscontacts.report_officer_roster</field>
    <field name="report_file">elkscontacts.report_officer_roster</field>
    <field name="print_report_name">'Officer_Roster'</field>
    <field name="binding_model_id" ref="model_elks_officer_term"/>
    <field name="binding_type">report</field>
  </record>

  <!-- Companion PDF report for download -->
  <record id="action_report_officer_roster_pdf" model="ir.actions.report">
    <field name="name">Officer Roster (PDF)</field>
    <field name="model">elks.officer.term</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">elkscontacts.report_officer_roster</field>
    <field name="report_file">elkscontacts.report_officer_roster</field>
    <field name="print_report_name">'Officer_Roster'</field>
    <field name="binding_model_id" ref="model_elks_officer_term"/>
    <field name="binding_type">report</field>
  </record>

  <!-- Reusable section template: takes a list of terms + a heading -->
  <template id="report_officer_roster_section">
    <t t-if="section_terms">
      <h4 class="mt-3" style="color: #555;">
        <t t-esc="section_label"/>
      </h4>
      <table class="table table-sm table-bordered">
        <thead>
          <tr style="background-color: #f0f0f0;">
            <th style="width: 30%;">Position</th>
            <th style="width: 25%;">Member</th>
            <th style="width: 20%;">Contact</th>
            <th style="width: 10%;">Partial Year</th>
            <th style="width: 15%;">Notes</th>
          </tr>
        </thead>
        <tbody>
          <t t-foreach="section_terms" t-as="term">
            <tr>
              <td>
                <t t-esc="dict(term._fields['position'].selection).get(term.position, term.position)"/>
              </td>
              <td>
                <t t-esc="term.partner_id.name"/>
              </td>
              <td style="font-size: 0.85em;">
                <t t-if="term.partner_id.email">
                  <t t-esc="term.partner_id.email"/><br/>
                </t>
                <t t-if="term.partner_id.phone">
                  <t t-esc="term.partner_id.phone"/>
                </t>
              </td>
              <td>
                <t t-if="term.partial_year">Yes</t>
              </td>
              <td>
                <t t-esc="term.notes or ''"/>
              </td>
            </tr>
          </t>
        </tbody>
      </table>
    </t>
  </template>

  <!-- Main roster template -->
  <template id="report_officer_roster">
    <t t-call="web.html_container">
      <t t-set="settings" t-value="docs[0].env['elks.lodge.settings'].sudo().search([], limit=1)" t-if="docs"/>

      <div class="page" style="font-size: 11px;">
          <!-- ===== LODGE HEADER WITH LOGOS ===== -->
          <table style="width: 100%; margin-bottom: 10px; border: none;">
              <tr>
                  <td style="width: 15%; text-align: center; vertical-align: middle; border: none; padding: 0;">
                      <t t-if="settings and settings.logo_primary">
                          <img t-att-src="image_data_uri(settings.logo_primary)"
                               style="max-height: 80px; max-width: 100px;" alt="Elks USA"/>
                      </t>
                  </td>
                  <td style="text-align: center; vertical-align: middle; border: none; padding: 0 10px;">
                      <h2 style="font-size: 22px; margin: 0 0 2px 0; color: #333;">
                          <t t-if="settings and settings.name"><span t-field="settings.name"/></t>
                          <t t-else="">Elks Lodge</t>
                          <t t-if="settings and settings.lodge_number">
                              #<span t-field="settings.lodge_number"/>
                          </t>
                      </h2>
                      <p style="color: #777; font-size: 11px; margin: 0;">
                          Benevolent and Protective Order of Elks
                      </p>
                      <h3 style="font-size: 18px; margin: 6px 0 0 0; color: #003366;">
                          Officer Roster
                      </h3>
                  </td>
                  <td style="width: 15%; text-align: center; vertical-align: middle; border: none; padding: 0;">
                      <t t-if="settings and settings.logo_lodge">
                          <img t-att-src="image_data_uri(settings.logo_lodge)"
                               style="max-height: 80px; max-width: 100px;" alt="Lodge Logo"/>
                      </t>
                  </td>
              </tr>
          </table>
          <div style="border-top: 2px solid #003366; margin-bottom: 15px;"/>

          <!-- Group terms by lodge year -->
          <t t-set="years" t-value="list(set(doc.lodge_year for doc in docs))"/>
          <t t-set="sorted_years" t-value="sorted(years, reverse=True)"/>

          <t t-foreach="sorted_years" t-as="year">
            <h3 class="mt-4 mb-3" style="border-bottom: 2px solid #333; padding-bottom: 4px;">
              Lodge Year: <t t-esc="year"/>
            </h3>

            <!-- Defined order so sections render trustees → elected → appointed → staff → honorific → delegate -->
            <t t-set="section_order" t-value="[
              ('elected', 'Elected Officers'),
              ('trustee', 'Board of Trustees'),
              ('appointed', 'Appointed Officers'),
              ('staff', 'Staff / Administrative'),
              ('honorific', 'Past / Honorific'),
              ('delegate', 'Delegates'),
            ]"/>

            <t t-foreach="section_order" t-as="ot">
              <t t-set="section_terms"
                 t-value="[d for d in docs if d.lodge_year == year and d.officer_type == ot[0]]"/>
              <t t-set="section_label" t-value="ot[1]"/>
              <t t-call="elkscontacts.report_officer_roster_section"/>
            </t>

            <!-- Anything that didn't classify (shouldn't happen but render anyway) -->
            <t t-set="other_terms"
               t-value="[d for d in docs if d.lodge_year == year and d.officer_type not in ['elected','trustee','appointed','staff','honorific','delegate']]"/>
            <t t-set="section_terms" t-value="other_terms"/>
            <t t-set="section_label" t-value="'Uncategorized'"/>
            <t t-call="elkscontacts.report_officer_roster_section"/>
          </t>

          <div class="mt-4 text-muted text-center" style="font-size: 0.85em;">
            <p>Printed on <t t-esc="datetime.date.today().strftime('%B %d, %Y')"/></p>
          </div>
        </div>
    </t>
  </template>

</odoo>
