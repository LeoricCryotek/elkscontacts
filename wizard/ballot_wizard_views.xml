<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_elks_ballot_wizard_form" model="ir.ui.view">
        <field name="name">elks.ballot.wizard.form</field>
        <field name="model">elks.ballot.wizard</field>
        <field name="arch" type="xml">
            <form string="Record Ballot Result">
                <group>
                    <field name="application_id" invisible="True"/>
                    <field name="applicant_name" string="Applicant"/>
                    <field name="ballot_date"/>
                    <field name="ballot_result" widget="radio"/>
                    <field name="all_in_favor"/>
                    <field name="votes_for" invisible="all_in_favor"/>
                    <field name="votes_against" invisible="all_in_favor"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
